rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Avatars: auth user can write own; anyone can read
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Service images: authenticated can write; anyone can read
    match /services/{serviceId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Event images: only the event's organizer can write; anyone can read.
    // The event doc is created before its image is uploaded, so we can
    // verify ownership against Firestore.
    match /events/{eventId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && firestore.get(/databases/(default)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
    }

    // Artist demos: auth user can write own; anyone can read
    match /artists/{userId}/demo/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    // Artist portfolio: auth user can write own; anyone can read
    match /artists/{userId}/portfolio/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Identity documents: PRIVATE. Only the owner and admins can read them;
    // only the owner can upload. Images or PDF, up to 10MB.
    match /identity/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperUser == true
      );
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }
  }
}
